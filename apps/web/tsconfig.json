{
  "extends": "@arctis/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "paths": {
      "@/*": ["./*"],
      "@arctis/ui": ["../../packages/ui/src/index.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "app/**/*",
    "features/**/*",
    "shared/**/*",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
